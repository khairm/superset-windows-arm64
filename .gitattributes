# Patch files MUST stay LF — the nightly runs `git apply patches/*.patch`
# on a Windows ARM64 runner (git default core.autocrlf=true). A CRLF patch
# fails to apply against LF upstream sources and aborts the build.
*.patch text eol=lf

# Shell scripts are executed by bash in CI; CRLF breaks the shebang/`\r`.
*.sh text eol=lf

# Node helper scripts run on the Windows runner; keep LF for consistency
# with the rest of the build tooling (node tolerates CRLF, but LF avoids
# noisy diffs and surprises).
*.mjs text eol=lf

# Fixup snippets are spliced verbatim into upstream TS files by the ARM64
# fixup step (C). Keep LF so the spliced result matches upstream's LF source.
*.snippet text eol=lf
