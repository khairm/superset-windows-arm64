diff --git a/apps/desktop/src/renderer/routes/_authenticated/_dashboard/kanban/components/KanbanCard/KanbanCard.tsx b/apps/desktop/src/renderer/routes/_authenticated/_dashboard/kanban/components/KanbanCard/KanbanCard.tsx
