diff --git a/apps/desktop/src/renderer/routes/_authenticated/_dashboard/kanban/components/KanbanBoard/KanbanBoard.tsx b/apps/desktop/src/renderer/routes/_authenticated/_dashboard/kanban/components/KanbanBoard/KanbanBoard.tsx
