+const ASK_MARKER_SCRIPT = `#!/usr/bin/env python3
+"""Superset AskUserQuestion marker hook.
+
+Installed by agent-jsonl-watcher/pane-map-hook.ts as PreToolUse + PostToolUse
+hooks, scoped by a settings.json matcher to the AskUserQuestion tool. On
+PreToolUse it writes ~/.superset/agent-ask-pending/<sessionId>.json the instant
+Claude shows a question; on PostToolUse it deletes that marker when the user
+answers. The agent-jsonl-watcher polls that dir and drives the red dot from it,
+so red is deterministic and does not depend on the JSONL read latency. Silent
+on every failure path — a broken hook must not abort the agent.
+"""
+import datetime
+import json
+import os
+import pathlib
+import sys
+
+
+def _log(record):
+    if os.environ.get("SUPERSET_AGENT_WATCHER_DEBUG") == "0":
+        return
+    try:
+        record["ts"] = datetime.datetime.now().isoformat()
+        log_dir = pathlib.Path.home() / ".superset"
+        log_dir.mkdir(parents=True, exist_ok=True)
+        with open(log_dir / "ask-marker-hook.log", "a", encoding="utf-8") as h:
+            h.write(json.dumps(record) + "\\n")
+    except Exception:
+        pass
+
+
+def _read_payload():
+    candidates = []
+    if len(sys.argv) > 1:
+        candidates.append(sys.argv[1])
+    try:
+        raw = sys.stdin.read()
+        if raw:
+            candidates.append(raw)
+    except (OSError, ValueError):
+        pass
+    for src in candidates:
+        try:
+            parsed = json.loads(src)
+        except (ValueError, TypeError):
+            continue
+        if isinstance(parsed, dict):
+            return parsed
+    return {}
+
+
+def main():
+    payload = _read_payload()
+    session_id = (payload.get("session_id") or payload.get("sessionId") or "").strip()
+    event = (payload.get("hook_event_name") or payload.get("hookEventName") or "").strip()
+    tool = (payload.get("tool_name") or payload.get("toolName") or "").strip()
+    cwd = (payload.get("cwd") or "").strip()
+    terminal_id = os.environ.get("SUPERSET_TERMINAL_ID", "").strip()
+    workspace_id = os.environ.get("SUPERSET_WORKSPACE_ID", "").strip()
+
+    # The settings.json matcher already scopes us to AskUserQuestion; double-
+    # check when the payload carries a tool name so a misconfig can't misfire.
+    if tool and tool != "AskUserQuestion":
+        return
+    if not session_id:
+        _log({"action": "skip", "reason": "no-session-id", "event": event})
+        return
+
+    marker_dir = pathlib.Path.home() / ".superset" / "agent-ask-pending"
+    marker_path = marker_dir / (session_id + ".json")
+
+    if event == "PreToolUse":
+        try:
+            marker_dir.mkdir(parents=True, exist_ok=True)
+            with open(marker_path, "w", encoding="utf-8") as h:
+                json.dump({
+                    "sessionId": session_id,
+                    "cwd": cwd,
+                    "terminalId": terminal_id,
+                    "workspaceId": workspace_id,
+                    "ts": datetime.datetime.now().isoformat(),
+                }, h)
+            _log({"action": "write", "sessionId": session_id, "cwd": cwd})
+        except Exception as exc:
+            _log({"action": "write-error", "error": str(exc)})
+    else:
+        # PostToolUse (or any non-Pre event) → clear, so a stray event can
+        # never leave the dot stuck red.
+        try:
+            marker_path.unlink()
+            _log({"action": "delete", "sessionId": session_id, "event": event})
+        except FileNotFoundError:
+            pass
+        except Exception as exc:
+            _log({"action": "delete-error", "error": str(exc)})
+
+
 if __name__ == "__main__":
     main()
