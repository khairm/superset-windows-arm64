diff --git a/apps/desktop/src/renderer/routes/_authenticated/_dashboard/components/KanbanReconciler/KanbanReconciler.tsx b/apps/desktop/src/renderer/routes/_authenticated/_dashboard/components/KanbanReconciler/KanbanReconciler.tsx
