+/**
+ * Normalize a cwd/worktree path for comparison: lowercase + forward slashes.
+ * Matches the normalization the Windows JSONL-watcher applies before emitting
+ * (`patches/agent-jsonl-watcher.patch`) so the strings line up on Windows,
+ * where path case and separator style vary between sources.
+ */
+function normalizeCwd(cwd: string): string {
+	return cwd.replace(/\\/g, "/").toLowerCase();
+}
+
+/**
+ * Resolve a terminalId for a workspace from its pane layout, given that the
+ * agent lifecycle event only told us the workspace (via cwd). Used by the
+ * Windows JSONL-watcher fallback when the event lacks a precise terminalId.
+ *
+ * Tie-break when a workspace has several terminals: the agent's cwd alone
+ * can't say which terminal it runs in, so we pick the lexicographically
+ * smallest terminalId deterministically. This keeps the dot stable across
+ * re-renders rather than flickering between terminals; the precise
+ * pane-map hook (when present) supersedes this with the real terminalId.
+ */
+function resolveTerminalIdFromPaneLayout(
+	paneLayout: WorkspaceState<PaneViewerData> | null | undefined,
+): string | null {
+	if (!paneLayout?.tabs) return null;
+	const terminalIds: string[] = [];
+	for (const tab of paneLayout.tabs) {
+		for (const pane of Object.values(tab.panes)) {
+			if (pane.kind !== "terminal") continue;
+			const data = pane.data as Partial<TerminalPaneData>;
+			if (typeof data.terminalId === "string" && data.terminalId) {
+				terminalIds.push(data.terminalId);
+			}
+		}
+	}
+	if (terminalIds.length === 0) return null;
+	if (terminalIds.length === 1) return terminalIds[0] ?? null;
+	return terminalIds.sort()[0] ?? null;
+}
