+/**
+ * Per-terminal statuses for a workspace, encoded as a comma-joined
+ * string for stable referential equality in the Zustand selector
+ * (returning an array would re-fire the subscription on every store
+ * change because [...] !== [...]). Callers split the string back to an
+ * array. Only terminal sources are included — chat sources excluded —
+ * with non-idle status; idle/missing entries are filtered.
+ */
+export function selectV2WorkspaceTerminalStatuses(workspaceId: string) {
+	return (state: V2NotificationState): string => {
+		const parts: string[] = [];
+		for (const entry of Object.values(state.sources)) {
+			if (entry.workspaceId !== workspaceId) continue;
+			if (entry.source.type !== "terminal") continue;
+			parts.push(entry.status);
+		}
+		return parts.join(",");
+	};
+}
+
+export function useV2WorkspaceTerminalStatuses(
+	workspaceId: string,
+): ActivePaneStatus[] {
+	const key = useV2NotificationStore(
+		selectV2WorkspaceTerminalStatuses(workspaceId),
+	);
+	return key ? (key.split(",") as ActivePaneStatus[]) : [];
+}
