+	/**
+	 * Like stopAll() but walks each host-service's process tree and escalates
+	 * to SIGKILL on stragglers (taskkill /F /T on Windows). stopAll()'s plain
+	 * SIGTERM doesn't propagate to grandchildren on Windows, leaving
+	 * pty-daemon / terminal-host orphans that hold the single-instance lock
+	 * and block the next app launch ("nothing happens" on relaunch).
+	 *
+	 * Order matters: tree-kill runs BEFORE stop()'s SIGTERM + manifest
+	 * removal. If stop() ran first the parent could die and have its PID
+	 * reused before taskkill /T walked the tree — Windows ParentProcessId
+	 * lookups would then either lose grandchildren or kill an unrelated
+	 * process. PIDs are snapshotted up front so concurrent spawn() calls
+	 * can't mutate the iteration set.
+	 */
+	async stopAllAndWaitTree(escalationTimeoutMs = 2000): Promise<void> {
+		const snapshot = Array.from(this.instances.entries())
+			.map(([id, inst]) => ({ id, pid: inst.pid }))
+			// pid === 0 means spawn() is mid-flight (instance is registered
+			// with pid 0 before the child PID is assigned). Tree-killing 0
+			// is dangerous — skip and let the race resolve naturally.
+			.filter(({ pid }) => pid > 0);
+		const results = await Promise.all(
+			snapshot.map(({ pid }) =>
+				treeKillWithEscalation({ pid, escalationTimeoutMs }),
+			),
+		);
+		for (let i = 0; i < snapshot.length; i++) {
+			const { id, pid } = snapshot[i];
+			const result = results[i];
+			if (!result.success) {
+				log.warn(
+					`[host-service:${id}] tree-kill of pid=${pid} failed during quit: ${result.error ?? "unknown"}`,
+				);
+			}
+			this.stop(id);
+		}
+	}
