+/**
+ * Best-effort populate of the normalized-worktree-path -> workspaceId cache
+ * used by the cwd fallback. Queries each workspace's host-service
+ * `workspace.get` (which returns `worktreePath`). Failures are swallowed
+ * per-workspace — a single unreachable host must not break resolution for the
+ * others, and the cwd fallback only ever degrades to "no dot", never to a
+ * crash.
+ */
+async function refreshCwdCache({
+	hostUrlByWorkspaceId,
+	cache,
+}: {
+	hostUrlByWorkspaceId: Map<string, string>;
+	cache: Map<string, string>;
+}): Promise<void> {
+	await Promise.all(
+		[...hostUrlByWorkspaceId.entries()].map(async ([workspaceId, hostUrl]) => {
+			try {
+				const workspace = await getHostServiceClientByUrl(
+					hostUrl,
+				).workspace.get.query({ id: workspaceId });
